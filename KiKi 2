/* ═══════════ STATE ═══════════ */
let selectedChapters = [];
let questionCount = "all";
let questions = [];
let idx = 0;
let selected = null;
let answered = false;
let score = 0;
let wrong = 0;
let missed = [];

const $ = id => document.getElementById(id);
const chapterNames = Object.keys(chapters);
const totalQ = Object.values(chapters).flat().length;

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

/* ═══════════ RENDER HOME ═══════════ */
function renderHome() {
  $("homeScreen").classList.remove("hidden");
  $("quizScreen").classList.add("hidden");
  $("resultsScreen").classList.add("hidden");

  $("totalCount").textContent = totalQ + " total questions across " + chapterNames.length + " chapters";

  const list = $("chapterList");
  list.innerHTML = "";
  chapterNames.forEach(ch => {
    const btn = document.createElement("button");
    btn.className = "chapter-btn" + (selectedChapters.includes(ch) ? " active" : "");
    btn.innerHTML = '<span>' + ch + '</span><span class="count">' + chapters[ch].length + " Q's</span>";
    btn.onclick = () => {
      if (selectedChapters.includes(ch)) selectedChapters = selectedChapters.filter(c => c !== ch);
      else selectedChapters.push(ch);
      renderHome();
    };
    list.appendChild(btn);
  });

  $("selectAllBtn").textContent = selectedChapters.length === chapterNames.length ? "Deselect All" : "Select All Chapters";
  $("selectAllBtn").onclick = () => {
    selectedChapters = selectedChapters.length === chapterNames.length ? [] : [...chapterNames];
    renderHome();
  };

  const totalAvail = selectedChapters.reduce((s, ch) => s + chapters[ch].length, 0);

  if (selectedChapters.length > 0) {
    $("countSection").classList.remove("hidden");
    $("availableLabel").textContent = "How many questions? (" + totalAvail + " available)";

    const row = $("countRow");
    row.innerHTML = "";
    ["20", "40", "60", "all"].forEach(opt => {
      const btn = document.createElement("button");
      const label = opt === "all" ? "All (" + totalAvail + ")" : opt;
      const disabled = opt !== "all" && parseInt(opt) > totalAvail;
      btn.className = "count-pill" + (questionCount === opt ? " active" : "");
      btn.textContent = label;
      btn.disabled = disabled;
      btn.onclick = () => { if (!disabled) { questionCount = opt; renderHome(); } };
      row.appendChild(btn);
    });
  } else {
    $("countSection").classList.add("hidden");
  }
}

/* ═══════════ START QUIZ ═══════════ */
function startQuiz() {
  let pool = [];
  selectedChapters.forEach(ch => {
    pool = pool.concat(chapters[ch].map(q => ({ ...q, chapter: ch })));
  });
  let shuffled = shuffle(pool);
  if (questionCount !== "all") shuffled = shuffled.slice(0, parseInt(questionCount));
  questions = shuffled.map(q => ({ ...q, options: shuffle(q.options) }));
  idx = 0; selected = null; answered = false; score = 0; wrong = 0; missed = [];

  $("homeScreen").classList.add("hidden");
  $("quizScreen").classList.remove("hidden");
  $("resultsScreen").classList.add("hidden");
  renderQuestion();
}

/* ═══════════ RENDER QUESTION ═══════════ */
function renderQuestion() {
  const cur = questions[idx];
  const progress = ((idx + 1) / questions.length) * 100;

  $("qNumber").textContent = (idx + 1) + " / " + questions.length;
  $("tallyRight").textContent = "\u2713 " + score;
  $("tallyWrong").textContent = "\u2717 " + wrong;
  $("progressBar").style.width = progress + "%";
  $("quizChapterTag").textContent = cur.chapter;
  $("questionText").textContent = cur.q;

  const optC = $("optionsContainer");
  optC.innerHTML = "";
  cur.options.forEach((opt, i) => {
    const btn = document.createElement("button");
    btn.className = "option-btn";
    btn.textContent = String.fromCharCode(65 + i) + ". " + opt;
    btn.onclick = () => handleSelect(opt);
    optC.appendChild(btn);
  });

  $("explanationBox").classList.add("hidden");
  $("nextBtn").classList.add("hidden");
}

function handleSelect(opt) {
  if (answered) return;
  selected = opt;
  answered = true;
  const cur = questions[idx];

  if (opt === cur.a) score++;
  else { wrong++; missed.push({ ...cur, userAnswer: opt }); }

  // Highlight options
  const btns = $("optionsContainer").querySelectorAll(".option-btn");
  btns.forEach(btn => {
    btn.disabled = true;
    const val = btn.textContent.substring(3); // strip "A. "
    if (val === cur.a) btn.classList.add("correct");
    else if (val === opt && opt !== cur.a) btn.classList.add("wrong");
  });

  if (cur.exp) {
    $("explanationBox").textContent = "\uD83D\uDCA1 " + cur.exp;
    $("explanationBox").classList.remove("hidden");
  }

  $("nextBtn").textContent = idx + 1 >= questions.length ? "See Results" : "Next Question \u2192";
  $("nextBtn").classList.remove("hidden");
}

function nextQuestion() {
  if (idx + 1 >= questions.length) {
    showResults();
  } else {
    idx++; selected = null; answered = false;
    renderQuestion();
  }
}

/* ═══════════ RESULTS ═══════════ */
function showResults() {
  $("quizScreen").classList.add("hidden");
  $("resultsScreen").classList.remove("hidden");

  const pct = Math.round((score / questions.length) * 100);
  const passed = pct >= 70;

  $("scoreCard").className = "score-card " + (passed ? "pass" : "fail");
  $("scorePct").className = "score-pct " + (passed ? "pass" : "fail");
  $("scorePct").textContent = pct + "%";
  $("scoreDetail").textContent = score + " correct out of " + questions.length;
  $("scoreBadge").className = "badge " + (passed ? "pass" : "fail");
  $("scoreBadge").textContent = passed ? "PASSING" : "NEEDS REVIEW";

  const sec = $("missedSection");
  sec.innerHTML = "";
  if (missed.length > 0) {
    sec.innerHTML = '<h3 class="review-title">Review Missed (' + missed.length + ')</h3>';
    missed.forEach(m => {
      const card = document.createElement("div");
      card.className = "missed-card";
      card.innerHTML =
        '<div class="ch-label">' + m.chapter + '</div>' +
        '<p class="mq">' + m.q + '</p>' +
        '<div class="your">Your answer: ' + m.userAnswer + '</div>' +
        '<div class="correct">Correct answer: ' + m.a + '</div>' +
        (m.exp ? '<div class="mexp">' + m.exp + '</div>' : '');
      sec.appendChild(card);
    });
  }
}

function goHome() {
  selectedChapters = [];
  questionCount = "all";
  renderHome();
}

/* ═══════════ EVENT LISTENERS ═══════════ */
$("startBtn").onclick = startQuiz;
$("exitBtn").onclick = goHome;
$("nextBtn").onclick = nextQuestion;
$("retryBtn").onclick = startQuiz;
$("changeBtn").onclick = goHome;

/* ═══════════ INIT ═══════════ */
renderHome();
</script>

